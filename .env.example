cat > .env.example << 'EOF'
# ── Django ────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_NAME=trading_dashboard
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ── Redis + Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Encryption (required) ─────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ── cTrader API ───────────────────────────────────────────────
CTRADER_CLIENT_ID=your_client_id_here
CTRADER_CLIENT_SECRET=your_client_secret_here
CTRADER_ACCESS_TOKEN=your_access_token_here
CTRADER_ACCOUNT_ID=your_account_id_here

# ── Google OAuth (django-allauth) ─────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── trading-analytics service ─────────────────────────────────
ANALYTICS_API_URL=http://localhost:8001/api/v1
